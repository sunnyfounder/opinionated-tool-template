# Timezone for Date, log rotation, and the scheduler. Defaults to
# Asia/Taipei if unset. Change only if the tool owner is outside Taiwan.
TZ=Asia/Taipei

# Port this tool listens on. Each deployed tool must have a unique port.
TOOL_PORT=3000

# Base path for the web UI. Must match the Nginx location block for this tool.
# Example: APP_BASE_PATH=/tools/{{TOOL_NAME}}
# Leave unset for local development (tool serves from /).
APP_BASE_PATH=

# Log level for pino. Valid values: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# ---------------------------------------------------------------
# Tool-specific env vars go below. Add them as you need them, and
# keep this file in sync so other people running this tool know
# what to set. Read them via src/config.ts — not process.env directly.
# ---------------------------------------------------------------
